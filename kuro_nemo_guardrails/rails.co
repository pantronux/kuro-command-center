import guardrails
import nemoguardrails.library.self_check.output_check

# Full dialog rails (no rails.input/output flows in YAML — avoids duplicate intrinsic parse in NeMo 0.21).
flow input rails $input_text
  await sniper jailbreak gate
  await sniper content safety input

flow output rails $output_text
  await sniper fact gate
  self check output
