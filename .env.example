# Kuro AI example environment.
# Copy to .env locally and fill real values there. Never commit real secrets.

# Deployment profile: local-dev, single-vm, docker-compose, staging, enterprise-pilot
KURO_DEPLOYMENT_PROFILE=local-dev
WORKING_DIR=/opt/kuro/runtime
TIMEZONE=Asia/Jakarta

# Security and auth
JWT_SECRET_KEY=change-me-use-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=12
ADMIN_USERNAME=Pantronux
ADMIN_PASSWORD_HASH=
FAIKHIRA_USERNAME=Faikhira
FAIKHIRA_PASSWORD_HASH=
COOKIE_SECURE=true
KURO_V2_STRICT_MODE=false

# Enterprise refactor control plane - defaults remain OFF.
KURO_ENTERPRISE_REFACTOR_ENABLED=false
KURO_MEMORY_V3_ENABLED=false
KURO_STORAGE_V2_ENABLED=false
KURO_CHAT_V2_ENABLED=false
KURO_MARKET_SENTINEL_V2_ENABLED=false
KURO_TELEGRAM_V2_ENABLED=false
KURO_PROVIDER_REGISTRY_V2_ENABLED=false
KURO_AGENT_TOOLS_V2_ENABLED=false
KURO_TASKS_V2_ENABLED=false
KURO_DEEP_RESEARCH_V2_ENABLED=false
KURO_WEB_SEARCH_V2_ENABLED=false
KURO_FRONTEND_V2_ENABLED=false
KURO_ADMIN_SETTINGS_V2_ENABLED=false
KURO_ENTERPRISE_OBSERVABILITY_ENABLED=false
KURO_API_V2_ENABLED=false

# Provider keys - leave blank unless enabling that provider.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Provider/model aliases - callers use aliases, not raw model IDs.
KURO_DEFAULT_PROVIDER=gemini
KURO_DEFAULT_MODEL_ALIAS=gemini_fast
KURO_PROVIDER_FALLBACK_ALIASES=gemini_fast
KURO_MODEL_GEMINI_FAST=gemini-3-flash-preview
KURO_MODEL_OPENAI_NANO=gpt-5.4-nano
KURO_MODEL_CLAUDE_FAST=claude-haiku-4-5
KURO_MODEL_DEEPSEEK_FAST=deepseek-v4-flash
MODEL_NAME=gemini-3-flash-preview

# Telegram
KURO_TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
KURO_TELEGRAM_RATE_LIMIT_PER_MIN=10
KURO_TELEGRAM_QUEUE_MAXSIZE=50
KURO_TELEGRAM_RESPONSE_TIMEOUT_S=180
KURO_TELEGRAM_DROP_PENDING_UPDATES=false
KURO_TELEGRAM_COCKPIT_ENABLED=true
KURO_TELEGRAM_CONFIRM_TTL_S=300
KURO_TELEGRAM_DIGEST_ENABLED=true
KURO_TELEGRAM_DIGEST_HOUR=8
KURO_TELEGRAM_CRITICAL_INSTANT=true

# Search, market, and external tools
SERPER_API_KEY=
NEWSAPI_API_KEY=
METACULUS_API_TOKEN=
NVD_API_KEY=
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:8765
OPENCLAW_API_KEY=
KURO_ADVISOR_AUTO_SEARCH=true
KURO_ADVISOR_MAX_SERPER_CALLS=3

# Database and runtime paths
KURO_FINANCE_DB_PATH=
KURO_MARKET_V2_DB_PATH=
KURO_TELEGRAM_V2_DB_PATH=
KURO_ENTERPRISE_OBSERVABILITY_DB_PATH=
KURO_PLAYGROUND_DB_PATH=
KURO_MEM0_STORAGE_DIR=
PHOENIX_WORKING_DIR=./phoenix_data
PHOENIX_SQL_DATABASE_URL=

# Backup and restore
KURO_BACKUP_ENABLED=true
KURO_BACKUP_DIR=./backups
KURO_BACKUP_RETAIN_DAYS=30
KURO_BACKUP_WEEKLY_RETAIN_WEEKS=8
KURO_BACKUP_PRE_MIGRATION_RETAIN_DAYS=7
KURO_BACKUP_COMPRESS_LEVEL=6
KURO_BACKUP_ALERT_ON_FAILURE=true

# Observability and evaluation
KURO_TRACE_SPAN_TIMEOUT_S=120
KURO_OBSERVABILITY_LOG_PROMPTS_ENABLED=false
KURO_EVAL_BATCH_RPM=5
KURO_EVAL_ALERT_THRESHOLD=0.6

# Proactive and background jobs
KURO_PROACTIVE_ENABLED=true
KURO_PROACTIVE_TELEGRAM_ENABLED=true
KURO_PROACTIVE_SEVERITY_FLOOR=warning
KURO_PROACTIVE_GREETING_ENABLED=true
KURO_PROACTIVE_GREETING_COOLDOWN_DAYS=1
