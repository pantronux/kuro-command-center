[Unit]
Description=Kuro Knowledge
After=network.target

[Service]
WorkingDirectory=/home/kuro/projects/kuro-knowledge
EnvironmentFile=/home/kuro/projects/kuro-knowledge/.env
ExecStart=/usr/bin/python3 -m uvicorn knowledge_main:app --host 127.0.0.1 --port 8088
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
